#include <iostream>
using namespace std;

int main() {

	int GameChoice, SettingsChoice, Color;
	int AmountQuest = 10;
	int TotalQuestions;
	int Lives = 3;
	int Wins = 0;
	int Exit = 0;
	int n = 0;
	int Answer;
	string Nickname = "Player";

	while (Exit == 0) {
		cout << "[ Welcome! ]" << endl;
		cout << " Start   [1] " << endl;
		cout << " Settings[2] " << endl;
		cout << " Rules   [3] " << endl;
		cout << " Exit    [0]" << endl;
		cin >> GameChoice;

		switch (GameChoice) {
		case 1: {
			cout << "Player: " << Nickname << endl;
			cout << "Lives: " << Lives << endl;
			cout << "Wins: " << Wins << endl;
			cout << "Questions: " << AmountQuest << endl;
			cout << "Press Any Key to Continue" << endl;
			system("pause");

			if (AmountQuest == 1) TotalQuestions = 12;
			else if (AmountQuest == 2) TotalQuestions = 10;
			else if (AmountQuest == 3) TotalQuestions = 8;
			else TotalQuestions = 10;

			string Questions[12] = {
				"What is a Variable in Programming?",
				"Which Data Type is Used to Store Integers?",
				"What is a Compiler?",
				"Which Operator is Used For Comparison in C++?",
				"What is a For Loop?",
				"Which Symbol is Used For Comments in C++?",
				"What is the main() Function?",
				"Which Data Type is Used For Decimal Numbers?",
				"What is an Array?",
				"Which Operator is Used For Logical AND?",
				"What is a Class in C++?",
				"Which Header File is Needed For input/output in C++?"
			};
			string Options[12][4] = {
				{"1) Container For Data", "2) Data Type", "3) Operator", "4) Function"},
				{"1) float", "2) string", "3) int", "4) char"},
				{"1) Code Interpreter", "2) Program That Translates Code to Machine Language", "3) Code Editor", "4) Debugger"},
				{"1) =", "2) ==", "3) !=", "4) <>"},
				{"1) Conditional Statement", "2) Switch Statement", "3) Loop With Parameter", "4) Assignment Operator"},
				{"1) //", "2) /* */", "3) #", "4) !"},
				{"1) Library", "2) Main Program Function", "3) Variable", "4) Class"},
				{"1) int", "2) char", "3) double/float", "4) bool"},
				{"1) Variable", "2) Collection of Elements of the Same Type", "3) Function", "4) Class"},
				{"1) ||", "2) &&", "3) !", "4) &"},
				{"1) Function", "2) Variable", "3) Template For Creating Objects", "4) Loop"},
				{"1) math.h", "2) string.h", "3) iostream", "4) stdio.h"}
			};

			int CorrectAnswers[12] = { 1, 3, 2, 2, 3, 1, 2, 3, 2, 2, 3, 3 };

			int currentLives = Lives;
			int currentWins = 0;

			for (int i = 0; i < TotalQuestions; i++) {
				system("cls");
				cout << "Question " << i + 1 << " of " << TotalQuestions << endl;
				cout << "Lives: " << currentLives << " | Wins: " << currentWins << endl;
				cout << Questions[i] << endl;

				for (int j = 0; j < 4; j++) {
					cout << Options[i][j] << endl;
				}
				cin >> Answer;

				if (Answer < 1 || Answer > 4) {
					cout << "Incorrect" << endl;
					currentLives--;
					cout << "Correct Answer Was: " << Options[i][CorrectAnswers[i] - 1] << endl;
					if (currentLives <= 0) {
						cout << "Game Over" << endl;
						break;
					}
					continue;
				}

				if (Answer == CorrectAnswers[i]) {
					cout << "Correct" << endl;
					currentWins++;
				}
				else {
					cout << "Incorrect" << endl;
					currentLives--;
					cout << "Correct Answer Was: " << Options[i][CorrectAnswers[i] - 1] << endl;
				}
				if (currentLives <= 0) {
					cout << "Game Over" << endl;
					return 0;
				}
			}
			system("cls");

			cout << "Player: " << Nickname << endl;
			cout << "Total Wins: " << currentWins << endl;
			cout << "Lives: " << currentLives << endl;

			if (currentWins >= TotalQuestions / 2) {
				Wins++;
			}
			break;
		}

		case 2: {
			system("cls");
			cout << "Change the Nickname            [1]" << endl;
			cout << "Change the Amount of Questions [2]" << endl;
			cout << "Change the Color of Interface  [3]" << endl;
			cout << "Exit the Menu                  [4]" << endl;
			cin >> SettingsChoice;

			if (SettingsChoice == 4) {
				break;
			}

			switch (SettingsChoice) {
			case 1:
				cout << "Enter the New Nickname: " << endl;
				cin >> Nickname;
				cout << "Nickname Changed to: " << Nickname << endl;
				system("pause");
				break;

			case 2:
				cout << "Enter the Amount of Questions: " << endl;
				cout << "12 Questions - [1] " << endl;
				cout << "10 Questions - [2] " << endl;
				cout << " 8 Questions - [3] " << endl;
				cin >> AmountQuest;
				system("pause");
				break;

			case 3:
				cout << "Choose the Text Color:" << endl;
				cout << "Blue - [1]" << endl;
				cout << "Red -  [2]" << endl;
				cin >> Color;
				if (Color == 1) {
					system("color 1");
				}
				else if (Color == 2) {
					system("color 4");
				}
				system("pause");
				break;
			}
			break;
		}

		case 3: {
			system("cls");
			cout << "The Player Gets Points For the Correct Answer to the Question" << endl;
			cout << "The Player Goes On For the Correct Answer" << endl;
			cout << "The Player Loses a Life For the Wrong Answer" << endl;
			cout << "Press 0 to Return to Menu..." << endl;
			cin >> n;
			break;
		}

		case 0: {
			Exit = 1;
			cout << "Goodbye Then" << endl;
			break;
		}

		default: {
			cout << "Invalid Choice. Try Again..." << endl;
			system("pause");
			break;
		}
		}
	}
	return 0;
}
